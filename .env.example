# =============================================================================
# Via — Environment Variables
# =============================================================================
# Copy this file to `.env` (gitignored) and fill in real values.
# Never commit `.env`. Never paste a filled `.env` in Discord, screenshots,
# or chat. If a key leaks, rotate it immediately.
# =============================================================================


# ----------------------------- Phase 1 — required ---------------------------

# MongoDB Atlas — connection string from the hackathon-provided cluster.
MONGODB_URI=mongodb+srv://USER:YOUR_PASSWORD_HERE@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=via
VECTOR_INDEX_NAME=memory_vector_index

# Voyage AI — embeddings for memory_facts.
VOYAGE_API_KEY=pa-...
VOYAGE_EMBED_MODEL=voyage-3.5
VOYAGE_EMBED_DIMENSIONS=1024

# Google Gemini — LLM for planner + specialists.
GOOGLE_API_KEY=...
LLM_MODEL=gemini-2.5-flash


# ----------------------------- Phase 2 — voice (uncomment when ready) -------

# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
# LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM


# ----------------------------- App config ------------------------------------

PORT=8000
CORS_ALLOW_ORIGINS=*
DEMO_USER_ID=alex
DEMO_TRIP_ID=trip_lisbon


# ----------------------------- Frontend (set in Vercel, NOT here) -----------
#
# NEXT_PUBLIC_API_BASE=http://localhost:8000
#
# =============================================================================
