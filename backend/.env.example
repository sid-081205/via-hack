# =============================================================================
# Via Backend — Environment Variables
# =============================================================================
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:YOUR_PASSWORD_HERE@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=via

# Google Gemini (LLM)
GOOGLE_API_KEY=...
LLM_MODEL=gemini-2.5-flash

# App config
PORT=8000
CORS_ALLOW_ORIGINS=*
DEMO_USER_ID=alex
DEMO_TRIP_ID=trip_lisbon
